<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ExpenseTracker" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/toolbar_bg</item>
        <item name="colorPrimaryDark">@color/status_bar</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="actionBarStyle">@style/Widget.ExpenseTracker.ActionBar</item>
        <item name="actionOverflowButtonStyle">@style/Widget.ExpenseTracker.OverflowButton</item>
        <item name="actionBarPopupTheme">@style/Widget.ExpenseTracker.PopupOverlay</item>
        <item name="android:datePickerDialogTheme">@style/Widget.ExpenseTracker.DatePicker</item>
        <item name="android:alertDialogTheme">@style/Widget.ExpenseTracker.Dialog</item>
        <item name="materialAlertDialogTheme">@style/Widget.ExpenseTracker.Dialog</item>
    </style>

    <style name="Theme.ExpenseTracker.NoActionBar" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/status_bar</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:datePickerDialogTheme">@style/Widget.ExpenseTracker.DatePicker</item>
        <item name="android:alertDialogTheme">@style/Widget.ExpenseTracker.Dialog</item>
        <item name="android:progressBarStyle">@style/Widget.ExpenseTracker.ProgressBar</item>
    </style>

    <style name="Widget.ExpenseTracker.ActionBar" parent="Widget.AppCompat.ActionBar.Solid">
        <item name="background">@color/toolbar_bg</item>
        <item name="titleTextStyle">@style/Widget.ExpenseTracker.ActionBar.Title</item>
        <item name="subtitleTextStyle">@style/Widget.ExpenseTracker.ActionBar.Subtitle</item>
    </style>

    <style name="Widget.ExpenseTracker.ActionBar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.ExpenseTracker.ActionBar.Subtitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Subtitle">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.ExpenseTracker.OverflowButton" parent="Widget.AppCompat.ActionButton.Overflow">
        <item name="android:tint">@color/white</item>
    </style>

    <style name="Widget.ExpenseTracker.PopupOverlay" parent="ThemeOverlay.MaterialComponents.Dark">
        <item name="android:colorBackground">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <style name="Widget.ExpenseTracker.ProgressBar" parent="android:Widget.ProgressBar">
        <item name="android:indeterminateTint">@color/primary</item>
    </style>

    <!-- Dark DatePicker and Dialogs -->
    <style name="Widget.ExpenseTracker.DatePicker" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Widget.ExpenseTracker.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/primary</item>
        <item name="android:windowBackground">@color/bg_surface</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.ExpenseTracker.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.ExpenseTracker.Dialog.Button</item>
    </style>

    <style name="Widget.ExpenseTracker.Dialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- Glass-style outlined text field -->
    <style name="Widget.ExpenseTracker.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/glass_input_bg</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.ExpenseTracker.TextInputLayout.Dropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/glass_input_bg</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>
</resources>
